---
interface Props {
  pollId: string;
  question: string;
  note?: string;
  options: { key: string; label: string; color: string }[];
}
const { pollId, question, note, options } = Astro.props;
---

<div id={`poll-${pollId}`} class="my-6 rounded-2xl overflow-hidden border border-[var(--color-accent)]/25 bg-[var(--color-accent)]/[0.04]">

  <!-- Header -->
  <div class="flex items-center gap-2 px-5 py-3 bg-[var(--color-accent)]/10 border-b border-[var(--color-accent)]/18">
    <svg class="w-3.5 h-3.5 text-[var(--color-accent)] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <polyline points="22 12 18 12 15 21 9 3 6 12 2 12" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
    <span class="font-mono text-[0.62rem] font-bold tracking-[0.12em] text-[var(--color-accent)] uppercase">// COMMUNITY_POLL</span>
    <span id={`badge-${pollId}`} class="hidden ml-auto font-mono text-[0.58rem] text-green-400 bg-green-400/10 border border-green-400/25 rounded-full px-2.5 py-0.5 tracking-widest">&#10003; VOTE_CAST</span>
  </div>

  <!-- Body -->
  <div class="px-6 pt-5 pb-3">
    <p class="font-mono text-[0.8rem] text-[var(--color-text-secondary)] mb-4 leading-relaxed">
      <span class="text-[var(--color-accent)] mr-1.5">&gt;</span>{question}
    </p>

    <!-- Vote buttons -->
    <div id={`options-${pollId}`} class="flex flex-col gap-2">
      {options.map((opt, i) => (
        <button
          data-poll={pollId}
          data-key={opt.key}
          data-color={opt.color}
          class="poll-btn flex items-center gap-3 px-4 py-2.5 rounded-lg border text-left font-mono text-[0.72rem] cursor-pointer transition-all duration-200"
          style={`border-color:${opt.color}30;background:${opt.color}08;color:#e0dcf4;`}
        >
          <span class="font-bold shrink-0" style={`color:${opt.color}`}>{String.fromCharCode(65 + i)}</span>
          <span>{opt.label}</span>
        </button>
      ))}
    </div>

    <!-- Results (hidden until voted) -->
    <div id={`results-${pollId}`} class="hidden flex-col gap-3"></div>
  </div>

  <!-- Footer -->
  <div class="px-6 pb-4 pt-1 flex flex-col gap-1.5">
    <span id={`total-${pollId}`} class="font-mono text-[0.58rem] text-[var(--color-text-muted)] tracking-wider">[ fetching vote data... ]</span>
    {note && (
      <p class="font-mono text-[0.62rem] text-[var(--color-text-muted)] leading-relaxed" set:html={note.replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2" target="_blank" rel="noopener" style="color:var(--color-accent);text-decoration:underline;text-underline-offset:3px;">$1</a>')} />
    )}
  </div>
</div>

<script define:vars={{ pollId, options }}>
  const STORAGE_KEY = 'xero_poll_' + pollId;
  const FB_CONFIG = {
    apiKey: 'AIzaSyDT_MJQFqPiRXwqJzRJN_VdNR9qF-1ki_s',
    authDomain: 'xerolinux-6e564.firebaseapp.com',
    projectId: 'xerolinux-6e564',
  };

  async function loadFirebase() {
    if (window.__fbPollApp) return window.__fbPollApp;
    const [{ initializeApp, getApps }, { getFirestore, doc, getDoc, setDoc, increment }] = await Promise.all([
      import('https://www.gstatic.com/firebasejs/10.14.1/firebase-app.js'),
      import('https://www.gstatic.com/firebasejs/10.14.1/firebase-firestore.js'),
    ]);
    const app = getApps().length ? getApps()[0] : initializeApp(FB_CONFIG);
    const db = getFirestore(app);
    window.__fbPollApp = { db, doc, getDoc, setDoc, increment };
    return window.__fbPollApp;
  }

  function renderBars(data, myVote) {
    const total = options.reduce((s, o) => s + (data[o.key] || 0), 0) || 1;
    const container = document.getElementById('results-' + pollId);
    container.innerHTML = options.map((o, i) => {
      const count = data[o.key] || 0;
      const pct = Math.round((count / total) * 100);
      const mine = o.key === myVote;
      return `<div style="display:flex;flex-direction:column;gap:0.22rem;">
        <div style="display:flex;justify-content:space-between;align-items:center;">
          <span style="font-family:monospace;font-size:0.68rem;color:${mine ? o.color : '#8884aa'};font-weight:${mine ? '700' : '400'};">
            ${String.fromCharCode(65 + i)} &mdash; ${o.label}${mine ? ' ◀' : ''}
          </span>
          <span style="font-family:monospace;font-size:0.62rem;color:${o.color};font-weight:700;">${pct}%</span>
        </div>
        <div style="height:4px;border-radius:9999px;background:rgba(255,255,255,0.06);overflow:hidden;">
          <div style="height:100%;width:${pct}%;background:${o.color};opacity:${mine ? '1' : '0.5'};border-radius:9999px;transition:width 0.7s ease;"></div>
        </div>
      </div>`;
    }).join('');
  }

  function showResults(data, myVote) {
    document.getElementById('options-' + pollId).style.display = 'none';
    const res = document.getElementById('results-' + pollId);
    res.style.display = 'flex';
    res.style.flexDirection = 'column';
    document.getElementById('badge-' + pollId).style.display = 'block';
    renderBars(data, myVote);
  }

  function updateTotal(data) {
    const total = options.reduce((s, o) => s + (data[o.key] || 0), 0);
    const el = document.getElementById('total-' + pollId);
    if (el) el.textContent = `[ total_votes: ${total} :: powered_by: firestore ]`;
  }

  async function init() {
    const { db, doc, getDoc } = await loadFirebase();
    const ref = doc(db, 'polls', pollId);
    const snap = await getDoc(ref);
    const data = snap.exists() ? snap.data() : {};
    updateTotal(data);
    const myVote = localStorage.getItem(STORAGE_KEY);
    if (myVote) showResults(data, myVote);
  }

  const buttons = document.querySelectorAll(`[data-poll="${pollId}"]`);
  console.log('[PollWidget] found buttons:', buttons.length, 'for poll:', pollId);

  buttons.forEach(btn => {
    btn.addEventListener('click', async () => {
      if (localStorage.getItem(STORAGE_KEY)) return;
      const key = btn.dataset.key;
      console.log('[PollWidget] vote clicked:', key);
      try {
        localStorage.setItem(STORAGE_KEY, key);
        const { db, doc, getDoc, setDoc, increment } = await loadFirebase();
        const ref = doc(db, 'polls', pollId);
        await setDoc(ref, { [key]: increment(1) }, { merge: true });
        const snap = await getDoc(ref);
        const data = snap.exists() ? snap.data() : {};
        showResults(data, key);
        updateTotal(data);
      } catch (err) {
        console.error('[PollWidget] vote failed:', err);
        localStorage.removeItem(STORAGE_KEY);
      }
    });
    btn.addEventListener('mouseover', () => { btn.style.background = btn.dataset.color + '18'; });
    btn.addEventListener('mouseout',  () => { btn.style.background = btn.dataset.color + '08'; });
  });

  init().catch(err => console.error('[PollWidget] init failed:', err));
</script>
