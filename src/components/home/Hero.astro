<script is:inline>
  // Hero gap data-stream canvas — picker style #100 (MULTICOLOR / MIXED_HEX_KAT)
  (function () {
    var c = document.getElementById('hero-stream');
    if (!c || window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    var SCHEMES = {
      GREEN_MATRIX:  { head: '#ffffff', trail: '#00ff88', tail: '#003311' },
      RED_ALERT:     { head: '#ffffff', trail: '#ff3333', tail: '#330000' },
      BLUE_DATA:     { head: '#ffffff', trail: '#3399ff', tail: '#001133' },
      AMBER_RETRO:   { head: '#ffffff', trail: '#ffaa00', tail: '#331a00' },
      CYAN_COLD:     { head: '#ffffff', trail: '#00ffff', tail: '#003333' },
      PURPLE_SYS:    { head: '#ffffff', trail: '#aa44ff', tail: '#1a0033' },
      XERO_ACCENT:   { head: '#ffffff', trail: '#a78bfa', tail: '#1a0f33' },
      // Layan-tuned, dimmer heads, softer trails
      LAYAN_INDIGO:  { head: '#d8daff', trail: '#5657f5', tail: '#0e1033' },
      LAYAN_MAGENTA: { head: '#ffd9f1', trail: '#ff80e0', tail: '#2a0a22' },
      LAYAN_VIOLET:  { head: '#ebe1ff', trail: '#a78bfa', tail: '#1a0f33' },
      LAYAN_AZURE:   { head: '#d8eaff', trail: '#6ea8ff', tail: '#0a1a33' },
      LAYAN_LAVENDER:{ head: '#e6dcff', trail: '#8a8bff', tail: '#11122a' }
    };
    var MULTI_KEYS = ['GREEN_MATRIX','RED_ALERT','BLUE_DATA','AMBER_RETRO','CYAN_COLD','PURPLE_SYS','XERO_ACCENT'];
    var LAYAN_KEYS = ['LAYAN_INDIGO','LAYAN_MAGENTA','LAYAN_VIOLET','LAYAN_AZURE','LAYAN_LAVENDER'];

    var KATAKANA = 'アイウエオカキクケコサシスセソタチツテトナニヌネノハヒフヘホマミムメモヤユヨラリルレロワヲン'.split('');
    var HEX = '0123456789ABCDEF'.split('');
    var CHARSETS = { MIXED_HEX_KAT: HEX.concat(KATAKANA), KATAKANA: KATAKANA, HEX: HEX };

    var p = {
      streamCount:  parseInt(c.dataset.streamCount, 10),
      speedLo:      parseFloat(c.dataset.speedLo),
      speedHi:      parseFloat(c.dataset.speedHi),
      trailLength:  parseInt(c.dataset.trailLength, 10),
      charSpacing:  parseFloat(c.dataset.charSpacing),
      fadeRate:     parseFloat(c.dataset.fadeRate),
      fontSize:     parseInt(c.dataset.fontSize, 10),
      glowRadius:   parseFloat(c.dataset.glowRadius),
      interval:     parseInt(c.dataset.interval, 10),
      charset:      CHARSETS[c.dataset.charset] || KATAKANA,
      schemeName:   c.dataset.scheme
    };

    var W = 16, H = 0;
    var ctx = c.getContext('2d');
    var dpr = window.devicePixelRatio || 1;

    function resize() {
      var rect = c.getBoundingClientRect();
      H = Math.max(120, rect.height);
      c.width = W * dpr;
      c.height = H * dpr;
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    }
    resize();
    var rt;
    window.addEventListener('resize', function () { clearTimeout(rt); rt = setTimeout(resize, 150); });

    function hexRgb(h) { return [parseInt(h.slice(1,3),16), parseInt(h.slice(3,5),16), parseInt(h.slice(5,7),16)]; }
    function rgbStr(rgb, a) { return 'rgba(' + rgb[0] + ',' + rgb[1] + ',' + rgb[2] + ',' + a + ')'; }
    function mix(a, b, t) { return [Math.round(a[0]+(b[0]-a[0])*t), Math.round(a[1]+(b[1]-a[1])*t), Math.round(a[2]+(b[2]-a[2])*t)]; }
    function trailColor(sc, i, n) {
      var tr = hexRgb(sc.trail), tl = hexRgb(sc.tail);
      var t = n <= 1 ? 0 : i / (n - 1);
      return mix(tr, tl, t);
    }
    function pickScheme() {
      if (p.schemeName === 'MULTICOLOR') return SCHEMES[MULTI_KEYS[Math.floor(Math.random()*MULTI_KEYS.length)]];
      if (p.schemeName === 'LAYAN_MULTI') return SCHEMES[LAYAN_KEYS[Math.floor(Math.random()*LAYAN_KEYS.length)]];
      return SCHEMES[p.schemeName] || SCHEMES.XERO_ACCENT;
    }

    function newStream() {
      return {
        x: -12 + Math.random() * 40,
        y: 20 + Math.random() * Math.max(40, H - 40),
        speed: p.speedLo + Math.random() * (p.speedHi - p.speedLo),
        trail: [],
        scheme: pickScheme(),
        frameCount: Math.floor(Math.random() * 5)
      };
    }
    var streams = [];
    for (var i = 0; i < p.streamCount; i++) streams.push(newStream());

    var visible = true;
    var io = new IntersectionObserver(function (entries) {
      visible = entries[0].isIntersecting;
    });
    io.observe(c);

    var animId;
    function frame() {
      animId = requestAnimationFrame(frame);
      if (!visible) return;
      ctx.clearRect(0, 0, W, H);
      ctx.font = p.fontSize + 'px monospace';
      ctx.textBaseline = 'middle';

      for (var s, si = 0; si < streams.length; si++) {
        s = streams[si];
        s.x += s.speed;
        s.frameCount++;

        if (s.frameCount % p.interval === 0) {
          s.trail.unshift({ char: p.charset[Math.floor(Math.random() * p.charset.length)], alpha: 1.0 });
          for (var ti = 1; ti < s.trail.length; ti++) s.trail[ti].alpha -= p.fadeRate;
          if (s.trail.length > p.trailLength) s.trail.length = p.trailLength;
          s.trail = s.trail.filter(function (t) { return t.alpha > 0.02; });
        }

        for (var ti2 = 0; ti2 < s.trail.length; ti2++) {
          var t = s.trail[ti2];
          var cx = s.x - ti2 * p.charSpacing;
          if (cx < -14 || cx > W + 14) continue;
          if (ti2 === 0) {
            ctx.shadowBlur = p.glowRadius;
            ctx.shadowColor = s.scheme.trail;
            ctx.fillStyle = s.scheme.head;
            ctx.fillText(t.char, cx, s.y);
            ctx.shadowBlur = 0;
          } else {
            var rgb = trailColor(s.scheme, ti2, p.trailLength);
            ctx.fillStyle = rgbStr(rgb, t.alpha);
            ctx.fillText(t.char, cx, s.y);
          }
        }

        if (s.x > W + 14) {
          s.x = -12;
          s.y = 20 + Math.random() * Math.max(40, H - 40);
          s.speed = p.speedLo + Math.random() * (p.speedHi - p.speedLo);
          s.trail = [];
          s.scheme = pickScheme();
        }
      }
    }
    requestAnimationFrame(frame);

    document.addEventListener('visibilitychange', function () {
      if (document.hidden && animId) { cancelAnimationFrame(animId); animId = null; }
      else if (!animId) { animId = requestAnimationFrame(frame); }
    });
  })();
</script>

<script is:inline>
  // Anniversary banner: hide client-side if past the end date (covers
  // pages built before expiry but viewed after).
  (function () {
    var el = document.getElementById('anniv-banner');
    if (!el) return;
    var end = el.getAttribute('data-end');
    if (!end) return;
    var endTime = new Date(end + 'T23:59:59').getTime();
    if (Date.now() > endTime) el.remove();
  })();

  // Conky-style segmented brick bars: smoothly fluctuate CPU/MEM/DSK/NET
  // so the sidebar feels like it's actually reading from the system.
  (function () {
    var wrap = document.querySelector('[data-conky]');
    if (!wrap) return;

    var rows = wrap.querySelectorAll('.hbar');
    if (!rows.length) return;

    var state = [];
    rows.forEach(function (row) {
      var track = row.querySelector('.hbar-t');
      var pct   = row.querySelector('.hbar-p');
      var min   = parseFloat(row.getAttribute('data-min')) || 10;
      var max   = parseFloat(row.getAttribute('data-max')) || 80;
      var label = (row.getAttribute('data-bar') || '').toUpperCase();
      var count = parseInt(track && track.getAttribute('data-bricks'), 10) || 18;

      // Spawn bricks once
      if (track && !track.children.length) {
        var frag = document.createDocumentFragment();
        for (var i = 0; i < count; i++) frag.appendChild(document.createElement('u'));
        track.appendChild(frag);
      }
      var bricks = track ? track.querySelectorAll('u') : [];

      state.push({
        row: row, track: track, bricks: bricks, pct: pct,
        min: min, max: max, label: label, count: count,
        val: (min + max) / 2,
      });
    });

    function tick() {
      state.forEach(function (s) {
        var range = s.max - s.min;
        var step  = (Math.random() - 0.5) * range * 0.45;
        var next  = s.val + step;
        if (next < s.min) next = s.min + Math.random() * range * 0.15;
        if (next > s.max) next = s.max - Math.random() * range * 0.15;
        s.val = next;
        var rounded = Math.round(next);
        var on = Math.round((rounded / 100) * s.count);
        for (var i = 0; i < s.bricks.length; i++) {
          s.bricks[i].classList.toggle('on', i < on);
        }
        if (s.pct) s.pct.textContent = rounded;
        s.row.setAttribute('title', s.label + ' ' + rounded + '%');
      });
    }

    var reduced = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    tick();
    if (!reduced) setInterval(tick, 1400);
  })();
</script>

<script is:inline>
(function () {
  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

  const canvas = document.getElementById('cmatrix-canvas');
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  const prompt = document.getElementById('cmatrix-prompt');
  const typed = document.getElementById('cmatrix-typed');
  const cursor = document.getElementById('cmatrix-cursor');
  const command = 'cmatrix';
  let charIndex = 0;
  let matrixStarted = false;
  let animId = null;
  let lastFrame = 0;
  let isVisible = true;
  const frameInterval = 70; // ms between frames — slower rain

  // Matrix characters (katakana + latin + digits)
  const chars = 'アイウエオカキクケコサシスセソタチツテトナニヌネノハヒフヘホマミムメモヤユヨラリルレロワヲンABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789@#$%^&*';

  // Layan palette — lead is bright white; trail picked per-column from full Layan accent rotation
  const leadColor = '#eaeaea';
  // Indigo, magenta, link blue, violet, green, warning amber, negative red — full Layan accents
  const trailPalette = ['#5657f5', '#ff80e0', '#4285f4', '#e040fb', '#2bd05a', '#f5b500', '#ee3939'];
  const dimPalette   = ['#3f40c8', '#c050a0', '#2a5dc0', '#9a2bb0', '#1f8a3a', '#a07900', '#a02828'];

  function resize() {
    const rect = canvas.parentElement.getBoundingClientRect();
    canvas.width = rect.width * window.devicePixelRatio;
    canvas.height = rect.height * window.devicePixelRatio;
    ctx.scale(window.devicePixelRatio, window.devicePixelRatio);
    canvas.style.width = rect.width + 'px';
    canvas.style.height = rect.height + 'px';
  }

  resize();
  let resizeTimer;
  window.addEventListener('resize', function () {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(function () {
      resize();
      if (matrixStarted) initDrops();
    }, 150);
  });

  // Pause when off-screen
  const observer = new IntersectionObserver(function (entries) {
    isVisible = entries[0].isIntersecting;
    if (!isVisible && animId) {
      cancelAnimationFrame(animId);
      animId = null;
    } else if (isVisible && matrixStarted && !animId) {
      lastFrame = 0;
      animId = requestAnimationFrame(drawMatrix);
    }
  }, { threshold: 0 });
  observer.observe(canvas.parentElement);

  const fontSize = 14;
  let columns, drops;

  function initDrops() {
    const w = canvas.width / window.devicePixelRatio;
    columns = Math.floor(w / fontSize);
    drops = [];
    for (let i = 0; i < columns; i++) {
      drops[i] = -(Math.random() * 40 | 0);
    }
  }

  function drawMatrix(timestamp) {
    if (!isVisible) { animId = null; return; }
    // Throttle frame rate for slower rain
    if (timestamp - lastFrame < frameInterval) {
      animId = requestAnimationFrame(drawMatrix);
      return;
    }
    lastFrame = timestamp;

    const w = canvas.width / window.devicePixelRatio;
    const h = canvas.height / window.devicePixelRatio;

    // Longer trails with slower fade
    ctx.fillStyle = (document.documentElement.getAttribute('data-theme') === 'dark') ? 'rgba(6, 7, 11, 0.08)' : 'rgba(26, 28, 34, 0.08)';
    ctx.fillRect(0, 0, w, h);

    ctx.font = fontSize + 'px monospace';

    for (let i = 0; i < columns; i++) {
      if (drops[i] < 0) {
        drops[i]++;
        continue;
      }

      const char = chars[Math.random() * chars.length | 0];
      const x = i * fontSize;
      const y = drops[i] * fontSize;

      if (y > 0 && y < h + fontSize) {
        // Per-column color picked from full Layan accent palette
        const colorIdx = i % trailPalette.length;
        const trailColor = trailPalette[colorIdx];
        const dimColor   = dimPalette[colorIdx];

        // Lead character — bright lavender/white
        ctx.fillStyle = leadColor;
        ctx.fillText(char, x, y);

        // One behind — bright Layan accent (per column)
        if (drops[i] > 1) {
          const c2 = chars[Math.random() * chars.length | 0];
          ctx.fillStyle = trailColor;
          ctx.fillText(c2, x, (drops[i] - 1) * fontSize);
        }

        // Two behind — dimmer variant of same accent
        if (drops[i] > 2) {
          const c3 = chars[Math.random() * chars.length | 0];
          ctx.fillStyle = dimColor;
          ctx.fillText(c3, x, (drops[i] - 2) * fontSize);
        }
      }

      drops[i]++;

      // Reset drop to top — slightly less frequent for longer streams
      if (drops[i] * fontSize > h && Math.random() > 0.985) {
        drops[i] = 0;
      }
    }

    animId = requestAnimationFrame(drawMatrix);
  }

  function typeCommand() {
    if (charIndex < command.length) {
      typed.textContent += command[charIndex];
      charIndex++;
      setTimeout(typeCommand, 120 + Math.random() * 100);
    } else {
      setTimeout(startMatrix, 500);
    }
  }

  function startMatrix() {
    prompt.style.opacity = '0';
    prompt.style.transition = 'opacity 0.3s';
    cursor.style.display = 'none';
    matrixStarted = true;

    const w = canvas.width / window.devicePixelRatio;
    const h = canvas.height / window.devicePixelRatio;
    ctx.fillStyle = (document.documentElement.getAttribute('data-theme') === 'dark') ? 'rgba(6, 7, 11, 1)' : 'rgba(26, 28, 34, 1)';
    ctx.fillRect(0, 0, w, h);

    initDrops();
    lastFrame = 0;
    animId = requestAnimationFrame(drawMatrix);
    // Rains continuously — no reset.
  }

  function resetTerminal() {
    if (animId) cancelAnimationFrame(animId);
    matrixStarted = false;

    const w = canvas.width / window.devicePixelRatio;
    const h = canvas.height / window.devicePixelRatio;
    ctx.clearRect(0, 0, w, h);

    typed.textContent = '';
    charIndex = 0;
    cursor.style.display = '';
    prompt.style.opacity = '1';

    setTimeout(typeCommand, 1200);
  }

  setTimeout(typeCommand, 800);
})();
</script>
