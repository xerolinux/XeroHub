---
import PageViews from '../ui/PageViews.astro';
import { Image } from 'astro:assets';
import logo from '../../assets/logo.png';
import lbFlag from '../../assets/lb.png';
const currentYear = new Date().getFullYear();
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const pageId = Astro.url.pathname.replace(/^\//, '').replace(/\/$/, '').replace(/\//g, '-') || 'home';

const socialLinks = [
  { label: 'GitHub', href: 'https://github.com/xerolinux', icon: 'github' },
  { label: 'Discord', href: 'https://discord.xerolinux.xyz', icon: 'discord' },
  { label: 'YouTube', href: 'https://youtube.com/@XeroLinux', icon: 'youtube' },
  { label: 'Mastodon', href: 'https://fosstodon.org/@XeroLinux', icon: 'mastodon' },
];

const footerLinks = [
  { label: 'About', href: `${base}/about/` },
  { label: 'Updates', href: `${base}/updates/` },
  { label: 'Gear', href: `${base}/gear/` },
  { label: 'Download', href: `${base}/download/` },
  { label: 'Wiki', href: 'https://wiki.xerolinux.xyz', external: true },
  { label: 'Merch', href: 'https://shop.xerolinux.xyz', external: true },
];
---

<footer class="relative z-10 mt-3 md:mt-8">
  <div class="news-rule hidden md:block mx-auto max-w-3xl px-4 sm:px-6">
    <span class="nr-tilde">~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~</span>
    <span class="nr-prompt"><span class="nr-user">xero</span><span class="nr-at">@</span><span class="nr-host">xerolinux</span><span class="nr-colon">:</span><span class="nr-path">~/hq</span><span class="nr-sigil">$</span>&nbsp;<span class="nr-cmd">echo</span>&nbsp;<span class="nr-str">"end of transmission"</span><span class="nr-cursor"></span></span>
    <span class="nr-tilde">~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~</span>
  </div>
  <div class="mx-auto max-w-7xl 2xl:max-w-[100rem] px-4 sm:px-6 lg:px-8 py-4 md:py-12">
    <div class="grid grid-cols-1 md:grid-cols-5 gap-6 items-center">
      <!-- Brand -->
      <div class="hidden md:block">
        <a href={`${base}/`} class="flex items-center gap-3 mb-4">
          <Image src={logo} alt="XeroLinux" width="72" height="72" densities={[1, 2]} loading="lazy" class="w-9 h-9 rounded-lg" />
          <span class="font-heading font-semibold text-lg text-[var(--color-text-primary)]">
            Xero<span class="text-[var(--color-accent)]">Linux</span>
          </span>
        </a>
        <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed">
          Our Base Of Operations...
        </p>
      </div>

      <!-- Col 2: Tech stack pills (fills space brand → nav) -->
      <div class="hidden md:flex flex-col items-center gap-2">
        <span class="font-mono text-[0.55rem] uppercase tracking-[0.2em] text-[var(--color-text-muted)]">Stack</span>
        <div class="grid grid-cols-2 gap-1.5 w-full max-w-[180px]">
          <span class="text-center px-2 py-1 rounded-full border border-[var(--color-accent)]/40 bg-[var(--color-accent)]/10 font-mono text-[0.55rem] uppercase tracking-[0.08em] text-[var(--color-accent-light)] leading-tight">astro</span>
          <span class="text-center px-2 py-1 rounded-full border border-[var(--color-link)]/40 bg-[var(--color-link)]/10 font-mono text-[0.55rem] uppercase tracking-[0.08em] text-[var(--color-link)] leading-tight">tailwind</span>
          <span class="text-center px-2 py-1 rounded-full border border-[var(--color-warning)]/40 bg-[var(--color-warning)]/10 font-mono text-[0.55rem] uppercase tracking-[0.08em] text-[var(--color-warning)] leading-tight">firebase</span>
          <span class="text-center px-2 py-1 rounded-full border border-[var(--color-positive)]/40 bg-[var(--color-positive)]/10 font-mono text-[0.55rem] uppercase tracking-[0.08em] text-[var(--color-positive)] leading-tight">layan</span>
        </div>
        <span class="font-mono text-[0.55rem] tracking-[0.14em] text-[var(--color-text-muted)] mt-1">GPL-3.0 · OSS</span>
      </div>

      <!-- Middle column: page views for current page -->
      <div class="flex flex-col items-center gap-2">
        <span class="font-mono text-[0.55rem] uppercase tracking-[0.2em] text-[var(--color-text-muted)]">Eyeballs</span>
        <PageViews pageId={pageId} />
        <span class="font-mono text-[0.52rem] tracking-[0.14em] text-[var(--color-text-muted)] mt-1">
          this page · all time
        </span>
      </div>

      <!-- Col 4: Project pulse — uptime + counts (fills space nav → community) -->
      <div class="hidden md:flex flex-col items-center gap-2">
        <span class="font-mono text-[0.55rem] uppercase tracking-[0.2em] text-[var(--color-text-muted)]">Pulse</span>
        <div class="grid grid-cols-3 gap-x-3 font-mono text-[0.62rem] uppercase tracking-[0.1em] text-[var(--color-text-muted)] text-center">
          <span class="flex flex-col items-center gap-0.5">
            <span class="text-base text-[var(--color-accent-light)] font-bold leading-none h-4 flex items-center">6+</span>
            <span class="text-[0.5rem]">years</span>
          </span>
          <span class="flex flex-col items-center gap-0.5">
            <span class="text-base text-[var(--color-accent-2)] font-bold leading-none h-4 flex items-center">v6</span>
            <span class="text-[0.5rem]">release</span>
          </span>
          <span class="flex flex-col items-center gap-0.5">
            <span class="text-base text-[var(--color-positive)] font-bold leading-none h-4 flex items-center">LIVE</span>
            <span class="text-[0.5rem] flex items-center gap-1 justify-center">
              <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-positive)]" style="animation:blink 1.4s ease-in-out infinite"></span>
              status
            </span>
          </span>
        </div>
        <a href={`${base}/updates/`} class="font-mono text-[0.55rem] uppercase tracking-[0.14em] text-[var(--color-text-muted)] hover:text-[var(--color-accent-light)] transition-colors">▸ changelog</a>
      </div>

      <!-- Socials -->
      <div class="hidden md:flex flex-col items-end text-right">
        <h3 class="font-heading font-semibold text-sm uppercase tracking-wider text-[var(--color-text-muted)] mb-4">
          Community
        </h3>
        <div class="flex gap-3">
          {socialLinks.map(link => (
            <a
              href={link.href}
              target="_blank"
              rel="noopener noreferrer"
              class="w-11 h-11 rounded-xl glass glass-hover flex items-center justify-center text-[var(--color-text-secondary)] hover:text-[var(--color-accent-light)] transition-all duration-200"
              aria-label={link.label}
              title={link.label}
            >
              {link.icon === 'github' && (
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
              )}
              {link.icon === 'discord' && (
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.317 4.3698a19.7913 19.7913 0 00-4.8851-1.5152.0741.0741 0 00-.0785.0371c-.211.3753-.4447.8648-.6083 1.2495-1.8447-.2762-3.68-.2762-5.4868 0-.1636-.3933-.4058-.8742-.6177-1.2495a.077.077 0 00-.0785-.037 19.7363 19.7363 0 00-4.8852 1.515.0699.0699 0 00-.0321.0277C.5334 9.0458-.319 13.5799.0992 18.0578a.0824.0824 0 00.0312.0561c2.0528 1.5076 4.0413 2.4228 5.9929 3.0294a.0777.0777 0 00.0842-.0276c.4616-.6304.8731-1.2952 1.226-1.9942a.076.076 0 00-.0416-.1057c-.6528-.2476-1.2743-.5495-1.8722-.8923a.077.077 0 01-.0076-.1277c.1258-.0943.2517-.1923.3718-.2914a.0743.0743 0 01.0776-.0105c3.9278 1.7933 8.18 1.7933 12.0614 0a.0739.0739 0 01.0785.0095c.1202.099.246.1981.3728.2924a.077.077 0 01-.0066.1276 12.2986 12.2986 0 01-1.873.8914.0766.0766 0 00-.0407.1067c.3604.698.7719 1.3628 1.225 1.9932a.076.076 0 00.0842.0286c1.961-.6067 3.9495-1.5219 6.0023-3.0294a.077.077 0 00.0313-.0552c.5004-5.177-.8382-9.6739-3.5485-13.6604a.061.061 0 00-.0312-.0286zM8.02 15.3312c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9555-2.4189 2.157-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.9555 2.4189-2.1569 2.4189zm7.9748 0c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9554-2.4189 2.1569-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.946 2.4189-2.1568 2.4189z"/></svg>
              )}
              {link.icon === 'youtube' && (
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
              )}
              {link.icon === 'mastodon' && (
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M23.268 5.313c-.35-2.578-2.617-4.61-5.304-5.004C17.51.242 15.792 0 11.813 0h-.03c-3.98 0-4.835.242-5.288.309C3.882.692 1.496 2.518.917 5.127.64 6.412.61 7.837.661 9.143c.074 1.874.088 3.745.26 5.611.118 1.24.325 2.47.62 3.68.55 2.237 2.777 4.098 4.96 4.857 2.336.792 4.849.923 7.256.38.265-.061.527-.132.786-.213.585-.184 1.27-.39 1.774-.753a.057.057 0 0 0 .023-.043v-1.809a.052.052 0 0 0-.02-.041.053.053 0 0 0-.046-.01 20.282 20.282 0 0 1-4.709.547c-2.73 0-3.463-1.284-3.674-1.818a5.593 5.593 0 0 1-.319-1.433.053.053 0 0 1 .066-.054 19.648 19.648 0 0 0 4.581.536c.394 0 .787 0 1.183-.007 2.053-.063 4.22-.166 6.236-.645 .052-.013.108-.02.16-.04 2.478-.53 4.835-2.187 5.083-5.137.012-.146.04-.61.04-.61.014-.207.153-2.07.087-3.16a.053.053 0 0 0 0-.007z"/></svg>
              )}
            </a>
          ))}
        </div>
      </div>
    </div>


    <!-- Bottom bar -->
    <div class="hidden md:flex mt-10 pt-8 border-t border-[var(--color-border)] flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-sm text-[var(--color-text-muted)]">
        &copy; {currentYear} XeroLinux. Proudly made in Lebanon <Image src={lbFlag} alt="Lebanese Flag" width="25" height="18" densities={[1, 2]} loading="lazy" class="inline-block align-text-bottom" />
      </p>
      <p class="text-sm text-[var(--color-text-muted)]">
        Built with <a href="https://astro.build" target="_blank" rel="noopener" class="text-[var(--color-accent-light)] hover:text-[var(--color-accent)] transition-colors">Astro</a> & <a href="https://tailwindcss.com" target="_blank" rel="noopener" class="text-[var(--color-accent-light)] hover:text-[var(--color-accent)] transition-colors">Tailwind</a>
      </p>
    </div>
  </div>
</footer>

