---
import { ticker } from '../../config';
import ThemeToggle from '../ui/ThemeToggle.astro';
import { Image } from 'astro:assets';
import logo from '../../assets/logo.png';
const pathname = Astro.url.pathname;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const ico = {
  home:     '<svg class="nav-ico" width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>',
  about:    '<svg class="nav-ico" width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>',
  updates:  '<svg class="nav-ico" width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m0 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4 4h-2m2 4h-2m-2-8H7m0 4H7m0 4H7"/></svg>',
  gear:     '<svg class="nav-ico" width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>',
  videos:   '<svg class="nav-ico" width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>',
  download: '<svg class="nav-ico" width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>',
  merch:    '<svg class="nav-ico" width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 11a1 1 0 01-1 1H5a1 1 0 01-1-1L5 9z"/></svg>',
};

const navLinks = [
  { label: 'Home', href: `${base}/`, icon: ico.home },
  { label: 'About', href: `${base}/about/`, icon: ico.about },
  { label: 'Updates', href: `${base}/updates/`, icon: ico.updates },
  { label: 'Gear', href: `${base}/gear/`, icon: ico.gear },
  { label: 'Videos', href: `${base}/videos/`, icon: ico.videos },
  { label: 'Download', href: `${base}/download/`, icon: ico.download },
];

const externalLinks = [
  { label: 'Merch', href: 'https://shop.xerolinux.xyz', icon: ico.merch },
];

// Date is rendered client-side (see inline script below) so the static
// build's "today" never drifts behind the visitor's real clock.
---

<header class="fixed top-0 left-0 right-0 z-50" id="site-header">
  <!-- Status bar: slim full-width WM-style strip ABOVE the masthead. Hidden on mobile. -->
  <div class="masthead-dateline" role="status" aria-label="Site status bar">
    <div class="mx-auto max-w-7xl 2xl:max-w-[100rem] px-4 sm:px-6 lg:px-8 masthead-dateline-inner">
      <span>Vol. MMXXVI</span>
      <span class="md-dot">·</span>
      <span id="masthead-date">&nbsp;</span>
      <span class="md-dot">·</span>
      <span class="md-accent" id="masthead-clock">--:--</span>
      <button type="button" id="clock-fmt" class="md-fmt" aria-label="Toggle 12/24 hour time">12H</button>
      <span class="md-dot">·</span>
      <span class="md-online"><span class="md-online-dot" aria-hidden="true"></span>online</span>
    </div>
  </div>

  <!-- Masthead body -->
  <div class="masthead-body">
    <div class="mx-auto max-w-7xl 2xl:max-w-[100rem] px-4 sm:px-6 lg:px-8">
      <script is:inline>
        (function () {
          var dateEl = document.getElementById('masthead-date');
          var el = document.getElementById('masthead-clock');
          var btn = document.getElementById('clock-fmt');
          var fmt = (function () { try { return localStorage.getItem('clockFormat') || '12'; } catch (e) { return '12'; } })();
          var lastDateStr = '';
          var DATE_OPTS = { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' };
          function tick() {
            var now = new Date();
            if (dateEl) {
              var ds = now.toLocaleDateString('en-GB', DATE_OPTS);
              if (ds !== lastDateStr) { dateEl.textContent = ds; lastDateStr = ds; }
            }
            if (el) {
              var t = now.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit', hour12: fmt === '12' });
              var tz = now.toLocaleTimeString([], { timeZoneName: 'short' }).split(' ').pop();
              el.textContent = t + ' · ' + tz;
            }
            if (btn) btn.textContent = fmt === '12' ? '12H' : '24H';
          }
          if (btn) btn.addEventListener('click', function () {
            fmt = fmt === '12' ? '24' : '12';
            try { localStorage.setItem('clockFormat', fmt); } catch (e) {}
            tick();
          });
          tick();
          setInterval(tick, 30000);
        })();
      </script>

      <!-- Nameplate row -->
      <div class="masthead-nameplate-row">
        <a href={`${base}/`} class="masthead-nameplate group">
          <Image src={logo} alt="XeroLinux" width="96" height="96" densities={[1, 2]} loading="eager" class="masthead-logo" />
          <span class="masthead-title">Xero<span class="masthead-title-accent">Linux</span><span class="masthead-caret"></span></span>
        </a>

        <!-- Right edge actions -->
        <div class="masthead-actions">
          <a
            href={`${base}/rss.xml`}
            target="_blank"
            rel="noopener noreferrer"
            class="masthead-rss"
            aria-label="RSS Feed"
            title="RSS Feed"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M6.18 15.64a2.18 2.18 0 012.18 2.18C8.36 19 7.38 20 6.18 20 5 20 4 19 4 17.82a2.18 2.18 0 012.18-2.18M4 4.44A15.56 15.56 0 0119.56 20h-2.83A12.73 12.73 0 004 7.27V4.44m0 5.66a9.9 9.9 0 019.9 9.9h-2.83A7.07 7.07 0 004 12.93V10.1z"/>
            </svg>
          </a>
          <div class="hidden sm:inline-flex"><ThemeToggle compact /></div>
        </div>

        <!-- Mobile menu button -->
        <button
          id="mobile-menu-btn"
          class="masthead-burger md:hidden"
          aria-label="Toggle menu"
          aria-expanded="false"
        >
          <svg class="w-6 h-6 menu-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <svg class="w-6 h-6 close-icon hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>

    </div>
  </div>

  <!-- Nav band: pulled out of the masthead-body so the top/bottom accent rules span 100vw, not just max-w-7xl -->
  <div class="masthead-nav-band hidden md:block">
    <div class="mx-auto max-w-7xl 2xl:max-w-[100rem] px-4 sm:px-6 lg:px-8">
      <nav class="masthead-nav">
        {navLinks.map(link => (
          <a
            href={link.href}
            class:list={[
              'masthead-navlink',
              (link.href === `${base}/` ? pathname === `${base}/` : pathname.startsWith(link.href))
                ? 'active'
                : ''
            ]}
          >
            <Fragment set:html={link.icon} />
            {link.label}
          </a>
        ))}
        {externalLinks.map(link => (
          <a href={link.href} target="_blank" rel="noopener noreferrer" class="masthead-navlink">
            <Fragment set:html={link.icon} />
            {link.label} ↗
          </a>
        ))}
      </nav>
    </div>
  </div>

  <!-- Edition ticker strip — always rendered; runtime date gate in Layout
       sets html[data-ticker] which the global CSS uses to hide when out of window. -->
  {ticker.items.length > 0 && (
    <div class="masthead-ticker">
      <div class="ticker-track">
        {ticker.items.map((item, i) => <span class={`tk-${i % 7}`}>★ {item}</span>)}
        {ticker.items.map((item, i) => <span class={`tk-${i % 7}`}>★ {item}</span>)}
      </div>
    </div>
  )}

  <!-- Mobile menu -->
  <div id="mobile-menu" class="masthead-mobile glass mx-4 mt-2 rounded p-4 hidden md:hidden">
    <div class="flex flex-col gap-1">
      {navLinks.map(link => (
        <a
          href={link.href}
          class:list={[
            'px-4 py-3 rounded text-sm font-mono uppercase tracking-wider transition-all duration-200',
            (link.href === `${base}/` ? pathname === `${base}/` : pathname.startsWith(link.href))
              ? 'bg-[var(--color-accent-subtle)] text-[var(--color-accent-light)]'
              : 'text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] hover:bg-[var(--color-bg-tertiary)]'
          ]}
        >
          {link.label}
        </a>
      ))}
      <div class="h-px bg-[var(--color-border)] my-2"></div>
      {externalLinks.map(link => (
        <a href={link.href} target="_blank" rel="noopener noreferrer" class="px-4 py-3 rounded text-sm font-mono uppercase tracking-wider text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] hover:bg-[var(--color-bg-tertiary)] transition-all duration-200 flex items-center justify-between">
          {link.label} ↗
        </a>
      ))}
      <a href={`${base}/rss.xml`} target="_blank" rel="noopener noreferrer" class="px-4 py-3 rounded text-sm font-mono uppercase tracking-wider text-orange-400 hover:text-orange-300 hover:bg-[var(--color-bg-tertiary)] transition-all duration-200">
        RSS Feed
      </a>
    </div>
  </div>
</header>

<style>
  .masthead-body {
    background: var(--color-bg-glass);
    backdrop-filter: blur(6px) saturate(150%);
    -webkit-backdrop-filter: blur(6px) saturate(150%);
  }
  /* Drop the box-shadow onto the whole fixed header wrapper so it sits below
     the last horizontal band (nav-band/ticker), not buried behind it. */
  #site-header { box-shadow: 0 10px 28px rgba(0,0,0,0.5); }
  /* WM-style status bar: thin, FULL-WIDTH band above the masthead. Glass-blurred like the rest of the masthead. */
  .masthead-dateline {
    width: 100%;
    background: var(--color-bg-glass);
    backdrop-filter: blur(6px) saturate(150%);
    -webkit-backdrop-filter: blur(6px) saturate(150%);
    border-bottom: 1px solid var(--color-border);
    color: var(--color-text-muted);
  }
  .masthead-dateline-inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 4px 10px;
    /* Vertically center the text between the per-element-accent top line and the bar's bottom border.
       Symmetric padding does the centering; the small extra top push clears the accent ribbon. */
    padding: 11px 0 9px;
    font-family: var(--font-mono);
    font-size: 0.62rem;
    line-height: 1;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    opacity: 0.82;
  }
  .masthead-dateline .md-dot { color: var(--color-accent); opacity: 0.55; }
  .masthead-dateline .md-accent { color: var(--color-accent-light); }
  .masthead-dateline .md-online {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    color: var(--color-positive, #2bd05a);
  }
  .masthead-dateline .md-online-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: currentColor;
    box-shadow: 0 0 6px currentColor;
    animation: md-online-pulse 1.8s ease-in-out infinite;
  }
  @keyframes md-online-pulse {
    0%, 100% { opacity: 1; }
    50%      { opacity: 0.4; }
  }
  @media (prefers-reduced-motion: reduce) {
    .masthead-dateline .md-online-dot { animation: none; }
  }
  .masthead-dateline .md-fmt {
    margin-left: 6px;
    padding: 1px 6px;
    font-family: inherit;
    font-size: 0.85em;
    letter-spacing: 0.08em;
    line-height: 1.4;
    color: var(--color-accent-light);
    background: rgba(86, 87, 245, 0.10);
    border: 1px solid rgba(86, 87, 245, 0.35);
    border-radius: 5px;
    cursor: pointer;
    transition: background 0.18s ease, border-color 0.18s ease, color 0.18s ease;
  }
  .masthead-dateline .md-fmt:hover {
    background: rgba(86, 87, 245, 0.22);
    border-color: var(--color-accent);
    color: #fff;
  }

  .masthead-nameplate-row {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 10px 0 8px;
  }
  .masthead-nameplate {
    display: flex;
    align-items: center;
    gap: 14px;
    text-decoration: none;
  }
  .masthead-logo {
    width: 46px; height: 46px; border-radius: 8px;
    transition: transform 0.3s;
  }
  .masthead-nameplate:hover .masthead-logo { transform: scale(1.08); }
  .masthead-title {
    font-family: var(--font-heading);
    font-weight: 900;
    font-size: clamp(2.1rem, 4.2vw, 3.2rem);
    letter-spacing: -0.02em;
    color: var(--color-text-primary);
    line-height: 1;
  }
  .masthead-title-accent { color: var(--color-accent); }
  .masthead-caret {
    display: inline-block;
    width: 9px;
    height: 0.78em;
    background: var(--color-accent);
    margin-left: 7px;
    vertical-align: baseline;
    animation: blink 1.1s step-end infinite;
  }

  .masthead-actions {
    position: absolute;
    right: 0;
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .masthead-rss { color: #ff8a1a; transition: color 0.2s, filter 0.2s; display: flex; filter: drop-shadow(0 0 4px rgba(255, 138, 26, 0.45)); }
  .masthead-rss:hover { color: #ffb15a; filter: drop-shadow(0 0 6px rgba(255, 138, 26, 0.7)); }

  .masthead-burger {
    position: absolute;
    right: 0;
    color: var(--color-text-secondary);
    transition: color 0.2s;
  }
  .masthead-burger:hover { color: var(--color-text-primary); }

  /* Nav band: full-width wrapper so the accent rules span 100vw, not just max-w-7xl. */
  .masthead-nav-band {
    width: 100%;
    border-top: 1px solid rgba(var(--top-accent, var(--col-accent)), 0.45);
    border-bottom: 1px solid rgba(var(--bottom-accent, var(--col-accent)), 0.45);
    background: var(--color-bg-glass);
    backdrop-filter: blur(6px) saturate(150%);
    -webkit-backdrop-filter: blur(6px) saturate(150%);
  }
  .masthead-nav {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    padding: 11px 0;
  }
  .masthead-navlink {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
    text-decoration: none;
    padding: 3px 18px;
    transition: color 0.2s;
    position: relative;
  }
  :global(.nav-ico) {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
    opacity: 0.85;
  }
  .masthead-navlink:hover :global(.nav-ico),
  .masthead-navlink.active :global(.nav-ico) { opacity: 1; }
  .masthead-navlink + .masthead-navlink { border-left: 1px solid var(--color-border); }
  .masthead-navlink:hover { color: var(--color-accent-light); }
  .masthead-navlink.active { color: var(--color-accent); }

  /* Rotate Layan accent colors across nav items so the bar feels alive */
  .masthead-navlink:nth-child(1) :global(.nav-ico) { color: var(--color-accent); }
  .masthead-navlink:nth-child(2) :global(.nav-ico) { color: var(--color-accent-2); }
  .masthead-navlink:nth-child(3) :global(.nav-ico) { color: var(--color-positive); }
  .masthead-navlink:nth-child(4) :global(.nav-ico) { color: var(--color-warning); }
  .masthead-navlink:nth-child(5) :global(.nav-ico) { color: var(--color-link); }
  .masthead-navlink:nth-child(6) :global(.nav-ico) { color: var(--color-accent-3); }
  .masthead-navlink:nth-child(7) :global(.nav-ico) { color: var(--color-negative); }

  .masthead-ticker {
    overflow: hidden;
    background: linear-gradient(100deg, #1a1c22 0%, #22232b 60%, #262838 100%);
    white-space: nowrap;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.03),
      0 4px 10px rgba(0, 0, 0, 0.22),
      0 2px 4px rgba(0, 0, 0, 0.18);
    border-top: 1px solid rgba(86, 87, 245, 0.10);
    position: relative;
    z-index: 2;
  }
  .ticker-track {
    display: inline-flex;
    padding: 7px 0;
    animation: ticker-scroll 75s linear infinite;
    will-change: transform;
    backface-visibility: hidden;
    -webkit-mask-image: linear-gradient(to right, transparent 0%, black 6%, black 94%, transparent 100%);
    mask-image: linear-gradient(to right, transparent 0%, black 6%, black 94%, transparent 100%);
  }
  .ticker-track span {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(180, 182, 196, 0.55);
    text-shadow: none;
    padding-right: 44px;
  }
  @keyframes ticker-scroll {
    0% { transform: translate3d(0, 0, 0); }
    100% { transform: translate3d(-50%, 0, 0); }
  }
  @media (prefers-reduced-motion: reduce) {
    .ticker-track { animation: none; }
  }
  /* Subtle alternating accent — every other item slightly accented, no rainbow */
  .ticker-track span.tk-0,
  .ticker-track span.tk-2,
  .ticker-track span.tk-4,
  .ticker-track span.tk-6 { color: rgba(180, 182, 196, 0.55); }
  .ticker-track span.tk-1,
  .ticker-track span.tk-3,
  .ticker-track span.tk-5 { color: color-mix(in srgb, var(--color-accent-light) 75%, rgba(180, 182, 196, 0.55)); }

  /* ── Mobile: shrink masthead, avoid RSS/burger overlap.
        Threshold aligned with the Tailwind md/lg breakpoint (600px) so the
        status bar + nav band + burger all flip together. No partial state. */
  @media (max-width: 599px) {
    .masthead-actions { display: none; }          /* RSS lives in the mobile menu */
    .masthead-dateline { display: none; }          /* status bar hidden on mobile, terminal aesthetic only on >= md */
    .masthead-nameplate-row { padding: 11px 0 9px; }
    .masthead-logo { width: 44px; height: 44px; }
    .masthead-title { font-size: 2.05rem; }
    .masthead-caret { height: 0.78em; width: 8px; margin-left: 6px; }
    .ticker-track span { font-size: 0.76rem; letter-spacing: 0.14em; padding-right: 36px; }
    .ticker-track { padding: 9px 0; }
  }
</style>

<script is:inline>
  const menuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const menuIcon = menuBtn?.querySelector('.menu-icon');
  const closeIcon = menuBtn?.querySelector('.close-icon');

  function closeMenu() {
    mobileMenu?.classList.add('hidden');
    menuIcon?.classList.remove('hidden');
    closeIcon?.classList.add('hidden');
    menuBtn?.setAttribute('aria-expanded', 'false');
  }
  function openMenu() {
    mobileMenu?.classList.remove('hidden');
    menuIcon?.classList.add('hidden');
    closeIcon?.classList.remove('hidden');
    menuBtn?.setAttribute('aria-expanded', 'true');
  }
  menuBtn?.addEventListener('click', () => {
    const isOpen = !mobileMenu?.classList.contains('hidden');
    if (isOpen) closeMenu(); else openMenu();
  });
  document.addEventListener('click', (e) => {
    if (!mobileMenu?.classList.contains('hidden') &&
        !mobileMenu?.contains(e.target) &&
        !menuBtn?.contains(e.target)) {
      closeMenu();
    }
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !mobileMenu?.classList.contains('hidden')) closeMenu();
  });
</script>
