---
// Site-wide background: data packets stepping along an invisible grid, like CPU/bus cycles.
// No trails, slow cadence, accent-colored glowing dots. Canvas, no gradients.
---

<canvas id="bg-flow" class="bg-flow" aria-hidden="true"></canvas>

<script is:inline>
  (function () {
    const canvas = document.getElementById('bg-flow');
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const CELL = 38;
    const DIRS = [[1, 0], [-1, 0], [0, 1], [0, -1]];
    let w, h, cols, rows, packets = [], animId, paused = false;
    let tick = 0;

    function spawn() {
      const d = DIRS[(Math.random() * 4) | 0];
      return {
        cx: (Math.random() * cols) | 0,
        cy: (Math.random() * rows) | 0,
        dx: d[0], dy: d[1],
        prog: 0,
        speed: 0.006 + Math.random() * 0.005,    // slower cell-to-cell step
        pink: Math.random() < 0.25,
        colIdx: (Math.random() * 3) | 0,         // smaller muted palette
        phase: Math.random() * Math.PI * 2,
      };
    }

    function build() {
      w = canvas.width = window.innerWidth;
      h = canvas.height = window.innerHeight;
      cols = Math.ceil(w / CELL);
      rows = Math.ceil(h / CELL);
      const count = Math.min((w * h) / 22000 | 0, window.innerWidth < 768 ? 40 : 100);
      packets = [];
      for (let i = 0; i < count; i++) packets.push(spawn());
    }

    function render() {
      // Read theme dynamically so Xero-Dark actually darkens the canvas bg
      ctx.fillStyle = (document.documentElement.getAttribute('data-theme') === 'dark') ? '#06070b' : '#212329';
      ctx.fillRect(0, 0, w, h);
      tick += 0.03;
      for (const p of packets) {
        p.prog += p.speed;
        if (p.prog >= 1) {
          p.prog = 0;
          p.cx += p.dx;
          p.cy += p.dy;
          // wrap
          if (p.cx < 0) p.cx = cols - 1; else if (p.cx >= cols) p.cx = 0;
          if (p.cy < 0) p.cy = rows - 1; else if (p.cy >= rows) p.cy = 0;
          // pure random roam at junctions — never gathers, ignores cursor
          if (Math.random() < 0.32) {
            if (p.dx) { p.dx = 0; p.dy = Math.random() < 0.5 ? 1 : -1; }
            else { p.dy = 0; p.dx = Math.random() < 0.5 ? 1 : -1; }
          }
        }
        const x = (p.cx + p.dx * p.prog) * CELL + CELL / 2;
        const y = (p.cy + p.dy * p.prog) * CELL + CELL / 2;
        // CPU-cycle pulse: size + brightness throb
        const pulse = 0.5 + 0.5 * Math.sin(tick + p.phase);
        const r = 0.8 + pulse * 0.6;
        const a = 0.06 + pulse * 0.10;
        // Muted Layan trio: indigo, soft magenta, slate
        const palette = ['86, 87, 245', '180, 110, 200', '120, 130, 160'];
        const col = palette[(p.colIdx ?? 0) % palette.length];
        ctx.shadowBlur = 1 + pulse * 1.5;
        ctx.shadowColor = 'rgba(' + col + ', 0.5)';
        ctx.fillStyle = 'rgba(' + col + ', ' + a + ')';
        ctx.beginPath();
        ctx.arc(x, y, r, 0, Math.PI * 2);
        ctx.fill();
        ctx.shadowBlur = 0;
      }
    }

    function loop() {
      animId = requestAnimationFrame(loop);
      if (paused) return;
      render();
    }

    document.addEventListener('visibilitychange', () => {
      if (document.hidden) {
        paused = true;
        if (animId) cancelAnimationFrame(animId);
      } else if (!reduce) {
        paused = false;
        animId = requestAnimationFrame(loop);
      }
    });

    let rt;
    window.addEventListener('resize', () => {
      clearTimeout(rt);
      rt = setTimeout(build, 160);
    });

    build();
    render();
    if (!reduce) animId = requestAnimationFrame(loop);
  })();
</script>
