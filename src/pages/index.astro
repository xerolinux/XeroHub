---
import Layout from '../components/layout/Layout.astro';
import Hero from '../components/home/Hero.astro';
import Carousel from '../components/home/Carousel.astro';
import FeatureCards from '../components/home/FeatureCards.astro';
import GlassCard from '../components/ui/GlassCard.astro';
import Button from '../components/ui/Button.astro';
import { kofiGoal, kofiGoalPct as fallbackPct } from '../config';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const KOFI_PROXY_URL = 'https://kofi-goal-proxy.techxero.workers.dev/';

let liveTitle: string = kofiGoal.title;
let liveTargetEUR: number = kofiGoal.targetEUR;
let liveCurrentEUR: number = kofiGoal.currentEUR;
let liveGoalPct: number = fallbackPct;

try {
  const res = await fetch(KOFI_PROXY_URL, {
    headers: { 'user-agent': 'xerohub-build' },
    signal: AbortSignal.timeout(5000),
  });
  if (res.ok) {
    const d = await res.json() as { percentage?: number; targetEUR?: number; currentEUR?: number; title?: string };
    if (typeof d.percentage === 'number') liveGoalPct = Math.max(0, Math.min(100, Math.floor(d.percentage)));
    if (typeof d.targetEUR === 'number')  liveTargetEUR = d.targetEUR;
    if (typeof d.currentEUR === 'number') liveCurrentEUR = d.currentEUR;
    if (d.title) liveTitle = d.title;
  }
} catch {
  // build-time fetch failed; keep config fallback values
}
---

<Layout title="Home" description="The XeroLinux HQ">
  <Hero />
  <Carousel />
  <FeatureCards />

  <!-- Arch Refined Section -->
  <section class="py-8 sm:py-20 px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl 2xl:max-w-[100rem]">
      <div class="fade-in news-section-head">
        <span class="news-num">02</span>
        <div class="news-title-wrap">
          <div class="news-kicker">// Feature</div>
          <h2 class="news-title">Arch, <em>Refined</em></h2>
        </div>
        <div class="news-line"></div>
      </div>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 sm:gap-8 lg:gap-12 items-center">
        <div>
          <div class="fade-in fade-in-delay-1 space-y-4 text-[var(--color-text-secondary)]">
            <p>
              <strong class="text-[var(--color-text-primary)]">XeroLinux</strong> represents an innovative <em>Arch-based</em> distribution designed to demystify the installation process while preserving the core principles of user-driven customization. This distribution offers a thoughtful approach to Linux that balances accessibility with the renowned flexibility of <strong class="text-[var(--color-text-primary)]">ArchLinux</strong>.
            </p>
            <p>
              <strong class="text-[var(--color-text-primary)]">XeroLinux</strong> embodies the true spirit of <strong class="text-[var(--color-text-primary)]">ArchLinux</strong>: a platform where you have the freedom to create your ideal computing environment, guided by curiosity, learning, and personal preference.
            </p>
          </div>
          <div class="fade-in fade-in-delay-2 mt-8">
            <Button href={`${base}/download/`}>
              Get Started
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
              </svg>
            </Button>
          </div>
        </div>
        <div class="fade-in fade-in-delay-2">
          <GlassCard padding="p-3">
            <div class="aspect-video rounded-xl overflow-hidden relative cursor-pointer group" id="yt-lite" data-vid="hj9I8UYXToY">
              <img
                src="https://i.ytimg.com/vi/hj9I8UYXToY/hqdefault.jpg"
                alt="XeroLinux Overview"
                width="480"
                height="360"
                loading="lazy"
                class="w-full h-full object-cover rounded-xl"
              />
              <!-- Play button overlay -->
              <div class="absolute inset-0 flex items-center justify-center bg-black/30 group-hover:bg-black/40 transition-colors rounded-xl">
                <div class="w-14 h-14 sm:w-16 sm:h-16 rounded-full flex items-center justify-center group-hover:scale-110 transition-transform backdrop-blur-md bg-white/10 border border-white/20 shadow-lg">
                  <svg class="w-6 h-6 sm:w-7 sm:h-7 text-white ml-1" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M8 5v14l11-7z"/>
                  </svg>
                </div>
              </div>
            </div>
          </GlassCard>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats / Quick Info -->
  <section class="py-6 sm:py-16 px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-5xl">
      <div class="fade-in news-section-head">
        <span class="news-num">03</span>
        <div class="news-title-wrap">
          <div class="news-kicker">// By the Numbers</div>
          <h2 class="news-title">The <em>Spec Sheet</em></h2>
        </div>
        <div class="news-line"></div>
      </div>
      <div class="fade-in stat-row">
        {[
          { icon: `<svg viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5 shrink-0"><path d="M13.881 0L9.89.382v16.435l3.949-.594V9.216l5.308 7.772 4.162-1.317-5.436-7.475 5.479-7.05L19.105.17 13.84 7.22zM4.834 4.005a.203.203 0 00-.123.059L3.145 5.63a.203.203 0 00-.03.248L4.949 8.9a7.84 7.84 0 00-.772 1.759l-3.367.7a.203.203 0 00-.162.199v2.215c0 .093.064.174.155.196l3.268.8a7.83 7.83 0 00.801 2.03L2.98 19.683a.203.203 0 00.027.254l1.566 1.567a.204.204 0 00.249.03l2.964-1.8c.582.336 1.21.6 1.874.78l.692 3.325c.02.094.102.161.198.161h2.215a.202.202 0 00.197-.155l.815-3.332a7.807 7.807 0 001.927-.811l2.922 1.915c.08.053.186.042.254-.026l1.567-1.566a.202.202 0 00.03-.248l-1.067-1.758-.345.11a.12.12 0 01-.135-.047L17.371 15.8a6.347 6.347 0 11-8.255-8.674V5.488c-.401.14-.79.31-1.159.511l-.001-.002-2.99-1.96a.203.203 0 00-.132-.033z"/></svg>`, value: 'KDE Plasma', label: 'Desktop' },
          { icon: `<svg viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5 shrink-0"><path d="M11.39.605C10.376 3.092 9.764 4.72 8.635 7.132c.693.734 1.543 1.589 2.923 2.554-1.484-.61-2.496-1.224-3.252-1.86C6.86 10.842 4.596 15.138 0 23.395c3.612-2.085 6.412-3.37 9.021-3.862a6.61 6.61 0 01-.171-1.547l.003-.115c.058-2.315 1.261-4.095 2.687-3.973 1.426.12 2.534 2.096 2.478 4.409a6.52 6.52 0 01-.146 1.243c2.58.505 5.352 1.787 8.914 3.844-.702-1.293-1.33-2.459-1.929-3.57-.943-.73-1.926-1.682-3.933-2.713 1.38.359 2.367.772 3.137 1.234-6.09-11.334-6.582-12.84-8.67-17.74z"/></svg>`, value: 'Arch Linux', label: 'Foundation' },
          { icon: `<svg viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5 shrink-0"><path d="M2 6a2 2 0 012-2h16a2 2 0 012 2v10a2 2 0 01-2 2h-5l1 2h1a1 1 0 110 2H7a1 1 0 110-2h1l1-2H4a2 2 0 01-2-2V6zm2 0v10h16V6H4z"/></svg>`, value: 'Wayland', label: 'Display Protocol' },
          { icon: `<svg viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5 shrink-0"><path d="M4 4a2 2 0 00-2 2v12a2 2 0 002 2h16a2 2 0 002-2V6a2 2 0 00-2-2H4zm0 2h16v12H4V6zm2 2v2h2V8H6zm3 0v2h2V8H9zm5 4v2h4v-2h-4z"/></svg>`, value: 'XeroHub', label: 'Toolkit' },
        ].map((stat) => (
          <div class="stat-cell">
            <div class="flex items-center justify-center gap-2 font-heading text-lg sm:text-xl font-bold text-[var(--color-accent)] mb-1">
              <Fragment set:html={stat.icon} />
              {stat.value}
            </div>
            <div class="font-mono text-[0.62rem] uppercase tracking-[0.14em] text-[var(--color-text-muted)]">
              {stat.label}
            </div>
          </div>
        ))}
      </div>

    </div>
  </section>

  <!-- Ko-Fi Goal Section -->
  <section class="pt-6 sm:pt-12 pb-2 sm:pb-3 px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-xl">
      <!-- Section header / separator -->
      <div class="fade-in flex items-center gap-3 sm:gap-4 mb-5 sm:mb-6">
        <div class="flex-1 h-px bg-gradient-to-r from-transparent via-[var(--color-accent)]/40 to-[var(--color-accent-2)]/40"></div>
        <div class="flex items-center gap-2 shrink-0">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-[var(--color-accent)]"><path d="M18 8h1a4 4 0 010 8h-1"/><path d="M2 8h16v9a4 4 0 01-4 4H6a4 4 0 01-4-4V8z"/><line x1="6" y1="1" x2="6" y2="4"/><line x1="10" y1="1" x2="10" y2="4"/><line x1="14" y1="1" x2="14" y2="4"/></svg>
          <span class="display-heading text-base sm:text-lg text-[var(--color-text-primary)] tracking-wide">Support <em class="italic text-[var(--color-accent)]">XeroLinux</em></span>
        </div>
        <div class="flex-1 h-px bg-gradient-to-l from-transparent via-[var(--color-accent-2)]/40 to-[var(--color-accent)]/40"></div>
      </div>

    {kofiGoal.enabled && (
      <div class="fade-in fade-in-delay-1">
        <a
          href={kofiGoal.link}
          target="_blank"
          rel="noopener noreferrer"
          class="kofi-goal-wrap block rounded-2xl px-4 sm:px-6 py-4 sm:py-5 group"
          data-kofi-goal
          data-kofi-endpoint="https://kofi-goal-proxy.techxero.workers.dev/"
        >
          <div class="flex items-center gap-3 mb-3">
            <span class="font-mono text-[0.58rem] uppercase tracking-[0.22em] text-[var(--color-accent)]">// Support Jar</span>
            <div class="flex-1 h-px bg-gradient-to-r from-[var(--color-accent)]/40 via-[var(--color-accent-2)]/25 to-transparent"></div>
            <span class="font-mono text-[0.55rem] uppercase tracking-[0.18em] text-[var(--color-text-muted)]">Ko-Fi</span>
          </div>

          <div class="flex items-baseline justify-between gap-3 mb-2">
            <span class="display-heading text-sm sm:text-base text-[var(--color-text-primary)] leading-tight" data-kofi-title>{liveTitle}</span>
            <span class="font-mono text-[0.62rem] sm:text-[0.68rem] tracking-widest text-[var(--color-accent-light)] shrink-0" data-kofi-pct>{liveGoalPct}%</span>
          </div>

          <div class="kofi-bar">
            <div class="kofi-bar-fill" style={`width: ${liveGoalPct}%`} data-kofi-fill>
              <span class="kofi-bar-shine"></span>
            </div>
            <div class="kofi-bar-ticks" aria-hidden="true">
              {Array.from({length: 9}).map((_, i) => <span style={`left: ${(i + 1) * 10}%`}></span>)}
            </div>
          </div>

          <div class="flex items-center justify-between gap-3 mt-2 font-mono text-[0.6rem] sm:text-[0.65rem] tracking-wider">
            <span class="text-[var(--color-text-secondary)]">
              <span class="text-[var(--color-positive)]" data-kofi-current>€{liveCurrentEUR.toLocaleString()}</span>
              <span class="text-[var(--color-text-muted)]"> / <span data-kofi-target>€{liveTargetEUR.toLocaleString()}</span></span>
            </span>
            <span class="text-[var(--color-text-muted)] group-hover:text-[var(--color-accent-light)] transition-colors flex items-center gap-1">
              Support
              <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
            </span>
          </div>
        </a>
      </div>
    )}
    </div>
  </section>

  <style>
    .kofi-goal-wrap {
      background: rgba(33, 35, 41, var(--layan-opacity, 0.6));
      backdrop-filter: var(--layan-blur, blur(6px) saturate(150%));
      -webkit-backdrop-filter: var(--layan-blur, blur(6px) saturate(150%));
      border: 1px solid rgba(179, 71, 255, 0.5);
      box-shadow:
        0 8px 24px rgba(0,0,0,0.30),
        0 0 14px rgba(62, 207, 110, 0.35),
        0 0 26px rgba(62, 207, 110, 0.18);
      text-decoration: none;
      transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
    }
    .kofi-goal-wrap:hover {
      transform: translateY(-2px);
      border-color: rgba(179, 71, 255, 0.75);
      box-shadow:
        0 12px 32px rgba(0,0,0,0.35),
        0 0 18px rgba(62, 207, 110, 0.45),
        0 0 34px rgba(62, 207, 110, 0.25);
    }
    :global(html[data-theme="dark"]) .kofi-goal-wrap {
      background: rgba(6, 7, 11, calc(var(--layan-opacity, 0.6) + 0.2));
      border-color: rgba(179, 71, 255, 0.42);
    }

    .kofi-bar {
      position: relative;
      height: 0.625rem;
      border-radius: 9999px;
      background: color-mix(in srgb, var(--color-accent) 8%, rgba(0,0,0,0.25));
      border: 1px solid color-mix(in srgb, var(--color-accent) 20%, transparent);
      overflow: hidden;
      box-shadow: inset 0 1px 3px rgba(0,0,0,0.35);
    }
    :global(html[data-theme="dark"]) .kofi-bar {
      background: color-mix(in srgb, var(--color-accent) 10%, rgba(6,7,11,0.7));
    }
    .kofi-bar-fill {
      position: relative;
      height: 100%;
      border-radius: 9999px;
      background: linear-gradient(90deg, var(--color-accent) 0%, var(--color-accent-2, #ff3eb5) 100%);
      box-shadow:
        0 0 8px color-mix(in srgb, var(--color-accent) 60%, transparent),
        0 0 16px color-mix(in srgb, var(--color-accent-2, #ff3eb5) 35%, transparent);
      transition: width 0.6s cubic-bezier(0.22, 1, 0.36, 1);
      overflow: hidden;
    }
    .kofi-bar-shine {
      position: absolute;
      inset: 0;
      background: linear-gradient(90deg, transparent 0%, rgba(255,255,255,0.35) 50%, transparent 100%);
      animation: kofi-shine 2.6s ease-in-out infinite;
    }
    @keyframes kofi-shine {
      0%   { transform: translateX(-100%); }
      55%  { transform: translateX(120%); }
      100% { transform: translateX(120%); }
    }
    .kofi-bar-ticks {
      position: absolute;
      inset: 0;
      pointer-events: none;
    }
    .kofi-bar-ticks span {
      position: absolute;
      top: 20%;
      bottom: 20%;
      width: 1px;
      background: rgba(255,255,255,0.08);
    }
  </style>

  <script is:inline>
    // Ko-Fi goal live updater — fetches CF Worker proxy, refreshes bar.
    (function () {
      const root = document.querySelector('[data-kofi-goal]');
      if (!root) return;
      const endpoint = root.dataset.kofiEndpoint;
      if (!endpoint) return;

      const elTitle   = root.querySelector('[data-kofi-title]');
      const elPct     = root.querySelector('[data-kofi-pct]');
      const elFill    = root.querySelector('[data-kofi-fill]');
      const elCurrent = root.querySelector('[data-kofi-current]');
      const elTarget  = root.querySelector('[data-kofi-target]');

      const fmt = (n) => '€' + Number(n).toLocaleString('en-US');

      function apply(data) {
        if (!data || typeof data !== 'object') return;
        const { percentage, targetEUR, currentEUR, title } = data;
        if (typeof percentage === 'number' && !Number.isNaN(percentage)) {
          const p = Math.max(0, Math.min(100, percentage));
          if (elPct)  elPct.textContent  = Math.floor(p) + '%';
          if (elFill) elFill.style.width = p + '%';
        }
        if (typeof targetEUR === 'number'  && elTarget)  elTarget.textContent  = fmt(targetEUR);
        if (typeof currentEUR === 'number' && elCurrent) elCurrent.textContent = fmt(currentEUR);
        if (title && elTitle) elTitle.textContent = title;
      }

      fetch(endpoint, { cache: 'no-store' })
        .then(r => r.ok ? r.json() : null)
        .then(apply)
        .catch(() => { /* keep build-time fallback */ });
    })();

    // YouTube lite-embed — load iframe only on click
    (function () {
      const yt = document.getElementById('yt-lite');
      if (yt) {
        yt.addEventListener('click', function () {
          const vid = yt.dataset.vid;
          const iframe = document.createElement('iframe');
          iframe.src = 'https://www.youtube.com/embed/' + vid + '?autoplay=1';
          iframe.className = 'w-full h-full rounded-xl';
          iframe.style.border = '0';
          iframe.setAttribute('allowfullscreen', '');
          iframe.setAttribute('allow', 'autoplay; encrypted-media');
          iframe.title = 'XeroLinux Overview';
          yt.innerHTML = '';
          yt.appendChild(iframe);
          yt.style.cursor = 'default';
        }, { once: true });
      }
    })();
  </script>
</Layout>
