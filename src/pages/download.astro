---
import { getEntry, render } from 'astro:content';
import Layout from '../components/layout/Layout.astro';
import GlassCard from '../components/ui/GlassCard.astro';
import Button from '../components/ui/Button.astro';
import ChangelogModal from '../components/ui/ChangelogModal.astro';
import PageViews from '../components/ui/PageViews.astro';
import { inlineMarkdown } from '../lib/inline-markdown';
import { discount, discountedPriceEUR } from '../config';
const pageId = Astro.url.pathname.replace(/^\//, '').replace(/\/$/, '').replace(/\//g, '-') || 'home';

const entry = await getEntry('pages', 'download');
const { Content } = await render(entry);
const { alert, isoFeatures, tuiFeatures } = entry.data;
---

<Layout title={entry.data.title} description={entry.data.description}>
  <section class="pt-44 sm:pt-52 pb-2 sm:pb-6 px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-6xl 2xl:max-w-[100rem]">
      <!-- Header -->
      <div class="fade-in text-center mb-3">
        <div class="news-kicker mb-2">// The Classifieds</div>
        <h1 class="dl-hero-title display-heading sm:text-5xl text-[var(--color-text-primary)] leading-none whitespace-nowrap">
          Looking for your next <em class="italic text-[var(--color-accent)]">Distro</em>?
        </h1>
      </div>
      <div class="fade-in flex justify-center mb-10">
        <PageViews pageId={pageId} />
      </div>

      <!-- Alert -->
      <div class="fade-in w-fit mx-auto mb-10">
        <div class="flex items-start gap-3 p-4 rounded-xl bg-orange-500/15 border border-orange-500/30 card-depth">
          <svg class="w-5 h-5 text-orange-400 shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z"/>
          </svg>
          <p class="text-sm text-orange-100">
            <strong class="text-orange-300">Note :</strong> <span class="prose-inline [&_strong]:text-orange-300" set:html={inlineMarkdown(alert!)} />
          </p>
        </div>
      </div>

      <!-- Intro editorial (two columns) -->
      <div class="fade-in fade-in-delay-1 max-w-5xl 2xl:max-w-[100rem] mx-auto mb-12 news-3col cols-2">
        <div class="news-col dropcap">
          <div class="news-col-kicker">// Editorial · The ISO</div>
          <h3 class="news-col-title">Welcome to XeroLinux</h3>
          <p>Welcome to the official <strong>XeroLinux</strong> download page. If you're just getting started, the <strong>ISO</strong> is your best bet, it comes with the <strong>Calamares</strong> GUI installer, which makes setup a breeze, while still giving you full control over manual drive partitioning. It's available through a small donation. This isn't a paywall or a demand, but a humble ask. If you find value in this project, your support goes a long way in keeping this project alive and actively developed. It also helps me weather the ongoing economic crisis here in <strong>Lebanon</strong>. Every bit counts, and I truly appreciate it.</p>
        </div>
        <div class="news-col">
          <div class="news-col-kicker">// Editorial · The T.U.I</div>
          <h3 class="news-col-title">The Free Alternative</h3>
          <p>However, if you are unable to donate, I completely understand. The <strong>T.U.I installer</strong> gives you the exact same full <strong>XeroLinux</strong> experience through a streamlined, user-friendly terminal-based setup, entirely free of charge. Beyond <strong>KDE Plasma</strong>, it also unlocks <strong>Hyprland</strong> and <strong>Noctalia-Shell</strong>, each pre-configured and ready to go right out of the box. It is fully open source, community-driven, and built for those who feel at home in the terminal. Both paths lead to the very same destination, so pick whichever suits you best. <strong>For Advanced Users !</strong></p>
        </div>
      </div>

      <!-- Changelog Button -->
      <div class="fade-in flex justify-center mb-10">
        <button
          data-changelog-modal
          class="inline-flex items-center gap-2 px-6 py-2.5 rounded-full glass text-sm font-medium text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] hover:border-[var(--color-border-hover)] transition-all duration-200 cursor-pointer"
        >
          <svg class="w-4 h-4 text-[var(--color-accent)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01" />
          </svg>
          View The XeroLinux Changelog
        </button>
      </div>

      <!-- Two Options -->
      <div class="fade-in news-section-head">
        <span class="news-num">01</span>
        <div class="news-title-wrap">
          <div class="news-kicker">// The Listings</div>
          <h2 class="news-title">Choose Your <em>Path</em></h2>
        </div>
        <div class="news-line"></div>
      </div>

      <!-- DE Choice Note — distinct accent so it doesn't clone the ISO card -->
      <div class="fade-in w-fit mx-auto mb-8" style="--col-accent: var(--acc-2);">
        <div class="flex items-start gap-3 p-5 classified bg-[var(--color-accent)]/[0.06]">
          <svg class="w-5 h-5 text-[var(--color-accent)] shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <p class="text-sm text-[var(--color-text-secondary)] whitespace-nowrap flex items-center gap-2 flex-wrap">
            <span class="text-[var(--color-text-muted)]">While</span>
            <strong class="text-[var(--color-accent)]">ISO</strong>
            <span class="text-[var(--color-text-muted)]">is</span>
            <a href="https://kde.org" target="_blank" rel="noopener" class="inline-flex items-center px-2 py-0.5 rounded-full bg-green-500/15 border border-green-500/30 text-green-300 text-xs font-bold tracking-wide hover:bg-green-500/25 transition-colors pill-depth">KDE Plasma</a>
            <span class="text-[var(--color-text-muted)]">Focused</span>
            <span class="text-[var(--color-accent)]/40 font-light select-none">|</span>
            <strong class="text-[var(--color-accent)]">T.U.I</strong>
            <span class="text-[var(--color-text-muted)]">unlocks</span>
            <a href="https://wiki.hypr.land/" target="_blank" rel="noopener" class="inline-flex items-center px-2 py-0.5 rounded-full bg-indigo-500/15 border border-indigo-500/30 text-indigo-300 text-xs font-bold tracking-wide hover:bg-indigo-500/25 transition-colors pill-depth">Hyprland</a>
            <span class="text-[var(--color-text-muted)]">with</span>
            <a href="https://noctalia.dev/" target="_blank" rel="noopener" class="inline-flex items-center px-2 py-0.5 rounded-full bg-[var(--color-accent)]/15 border border-[var(--color-accent)]/30 text-[var(--color-accent)] text-xs font-bold tracking-wide hover:bg-[var(--color-accent)]/25 transition-colors pill-depth">Noctalia-Shell</a>
            <span class="text-[var(--color-text-muted)]">both pre-configured.</span>
          </p>
        </div>
      </div>

      <div class="rainbow grid grid-cols-1 lg:grid-cols-2 gap-4 sm:gap-6 lg:gap-8 mb-10 sm:mb-16">
        <!-- ISO Option -->
        <div class="fade-in fade-in-delay-1">
          <GlassCard padding="p-4 sm:p-6 lg:p-8" class="h-full flex flex-col relative overflow-hidden classified">
            <div class="sale-stamp discount-on">
              <span class="sale-stamp-pct">{discount.percent}%</span>
              <span class="sale-stamp-off">OFF</span>
              <span class="sale-stamp-sub">{discount.label}</span>
            </div>
            <div class="flex items-center justify-between mb-5">
              <span class="font-mono text-[0.58rem] uppercase tracking-[0.2em] text-[var(--color-text-muted)]">ISO · KDE Plasma</span>
              <span class="font-mono text-[0.58rem] uppercase tracking-[0.14em] px-3 py-1 rounded-full bg-green-500/15 border border-green-500/40 text-green-300 pill-depth">Paid</span>
            </div>
            <h2 class="display-heading text-4xl text-[var(--color-text-primary)] leading-none mb-1">
              XeroLinux ISO
            </h2>
            <p class="text-xs uppercase tracking-wider text-green-400 font-medium mb-6 font-mono">
              One-Time Contribution · Ref. ISO-KDE
            </p>

            <div class="ad-rule"><span>Highlights</span><div class="l"></div></div>

            <ul class="mb-6 flex-1">
              {isoFeatures!.map(feature => (
                <li class="spec-li">
                  <span class="mk text-green-400">&#10003;</span>
                  <span set:html={feature} />
                </li>
              ))}
            </ul>

            <!-- Price — both states rendered; runtime gate hides the wrong one. -->
            <div class="mb-5 flex items-baseline gap-3 discount-on">
              <span class="font-mono text-base text-[var(--color-text-muted)] line-through decoration-[#ff80e0]/70">€{discount.basePriceEUR}</span>
              <span class="display-heading text-4xl text-[var(--color-text-primary)] leading-none">€{discountedPriceEUR}</span>
              <span class="font-mono text-[0.6rem] uppercase tracking-[0.12em] text-[#ff80e0]">Save {discount.percent}% · {discount.note}</span>
            </div>
            <div class="mb-5 flex items-baseline gap-3 discount-off">
              <span class="display-heading text-4xl text-[var(--color-text-primary)] leading-none">€{discount.basePriceEUR}</span>
              <span class="font-mono text-[0.6rem] uppercase tracking-[0.12em] text-[var(--color-text-muted)]">one-time · lifetime</span>
            </div>

            <p class="ad-note">Simple, beginner-friendly install.</p>

            <div class="flex gap-3 pt-4 border-t border-green-500/10">
              <Button href="https://ko-fi.com/s/cf9def9630" external class="flex-1 discount-off">
                Get on Ko-Fi
              </Button>
              <Button href="https://ko-fi.com/xerolinux/link/ANN25" external class="flex-1 discount-on">
                {discount.label} on Ko-Fi
              </Button>
              <Button href="/crypto/" variant="secondary" class="flex-1">
                Crypto Portal
              </Button>
            </div>
          </GlassCard>
        </div>

        <!-- TUI Option -->
        <div class="fade-in fade-in-delay-2">
          <GlassCard padding="p-4 sm:p-6 lg:p-8" class="h-full flex flex-col relative overflow-hidden classified free">
            <div class="flex items-center justify-between mb-5">
              <span class="font-mono text-[0.58rem] uppercase tracking-[0.2em] text-[var(--color-text-muted)]">T.U.I · Any Desktop</span>
              <span class="font-mono text-[0.58rem] uppercase tracking-[0.14em] px-3 py-1 rounded-full bg-[#3ecf6e]/15 border border-[#3ecf6e]/40 text-[#3ecf6e] pill-depth">Free</span>
            </div>
            <h2 class="display-heading text-4xl text-[var(--color-text-primary)] leading-none mb-1">
              XeroLinux T.U.I
            </h2>
            <p class="text-xs uppercase tracking-wider text-indigo-400 font-medium mb-6 font-mono">
              Completely Free · Ref. TUI-MULTI
            </p>

            <div class="ad-rule"><span>Highlights</span><div class="l"></div></div>

            <ul class="mb-6 flex-1">
              {tuiFeatures!.map(feature => (
                <li class="spec-li">
                  <span class="mk text-indigo-400">&#10003;</span>
                  <span>{feature}</span>
                </li>
              ))}
            </ul>

            <!-- Price area: mirrors ISO card layout so both cards read as siblings -->
            <div class="mb-5 flex items-baseline gap-3">
              <span class="display-heading text-4xl text-[#3ecf6e] leading-none">&euro;0</span>
              <span class="font-mono text-[0.6rem] uppercase tracking-[0.12em] text-[var(--color-text-muted)]">free forever &middot; community-driven</span>
            </div>

            <p class="ad-note warn">Terminal-based. Full control.</p>

            <div class="flex gap-3 pt-4 border-t border-indigo-500/10">
              <Button href="https://wiki.xerolinux.xyz/xero-install/" external class="flex-1">
                Read the Wiki
              </Button>
              <Button href="https://github.com/xerolinux/XeroHub/tree/main/public/script/xero-install" external variant="secondary" class="flex-1">
                GitHub
              </Button>
              <Button href="https://discord.xerolinux.xyz" external variant="secondary" class="flex-1">
                Discord
              </Button>
            </div>
          </GlassCard>
        </div>
      </div>

      <!-- Side Project: stronger break so users see this isn't a third main download. -->
      <div class="fade-in side-project-break" aria-hidden="true">
        <span class="spb-line"></span>
        <span class="spb-label">/* end of main listings */</span>
        <span class="spb-line"></span>
      </div>
      <div class="fade-in news-section-head side-project-head">
        <span class="news-num">02</span>
        <div class="news-title-wrap">
          <div class="news-kicker"><span class="side-project-pill">Side Project</span> <span class="opacity-70">// Not a primary download</span></div>
          <h2 class="news-title">The Fedora <em>Detour</em></h2>
        </div>
        <div class="news-line"></div>
      </div>

      <div class="fade-in fade-in-delay-3 mb-2 sm:mb-4">
        <GlassCard padding="p-4 sm:p-6 lg:p-8" class="relative overflow-hidden classified" style="--col-accent: var(--acc-3);">
          <div class="flex flex-col lg:flex-row lg:items-center gap-6 lg:gap-8">
            <div class="flex-1 min-w-0">
              <div class="flex items-center justify-between mb-3">
                <span class="font-mono text-[0.58rem] uppercase tracking-[0.2em] text-[var(--color-text-muted)]">Script · Fedora KDE</span>
                <span class="font-mono text-[0.58rem] uppercase tracking-[0.14em] px-3 py-1 rounded-full bg-[#3ecf6e]/15 border border-[#3ecf6e]/40 text-[#3ecf6e] pill-depth">Free</span>
              </div>
              <h2 class="display-heading text-3xl sm:text-4xl text-[var(--color-text-primary)] leading-none mb-1">
                XeroDora
              </h2>
              <p class="text-xs uppercase tracking-wider text-[var(--color-accent)] font-medium mb-4 font-mono">
                One-Command Setup · Ref. FEDORA-KDE
              </p>

              <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed mb-4">
                Automated post-install script that transforms a fresh <strong class="text-[var(--color-text-primary)]">Fedora</strong> install into a fully configured <strong class="text-[var(--color-text-primary)]">KDE Plasma</strong> desktop in a single command. Wires up <strong class="text-[var(--color-text-primary)]">RPMFusion</strong> (free + nonfree), <strong class="text-[var(--color-text-primary)]">Flathub</strong>, and <strong class="text-[var(--color-text-primary)]">Terra</strong> repos, pulls down multimedia codecs, and ships a curated app selector via an interactive menu. Optional integration with XeroLinux rice configurations.
              </p>

              <div class="flex items-start gap-3 p-3 rounded-xl bg-orange-500/10 border border-orange-500/30">
                <svg class="w-5 h-5 text-orange-400 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01M5.07 19h13.86c1.54 0 2.5-1.67 1.73-3L13.73 4a2 2 0 00-3.46 0L3.34 16c-.77 1.33.19 3 1.73 3z" />
                </svg>
                <p class="text-xs text-orange-100">
                  <strong class="text-orange-300">Heads up :</strong> side project, not as actively maintained as the main <strong class="text-orange-300">XeroLinux</strong> ISO + T.U.I. Use at your own discretion.
                </p>
              </div>
            </div>

            <div class="lg:w-64 lg:shrink-0 lg:border-l lg:border-[var(--color-accent)]/15 lg:pl-8 pt-4 lg:pt-0 border-t lg:border-t-0 border-[var(--color-accent)]/15">
              <Button href="https://github.com/xerolinux/XeroDora" external variant="secondary" class="w-full">
                View on GitHub
              </Button>
              <p class="ad-note mt-3 text-center">Shell · GPL-3.0</p>
            </div>
          </div>
        </GlassCard>
      </div>
    </div>
  </section>

  <ChangelogModal />
</Layout>

<style>
  .sale-stamp {
    position: absolute;
    top: 84px;
    right: 18px;
    z-index: 20;
    width: 84px;
    height: 84px;
    border-radius: 50%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    border: 2px dashed #ff80e0;
    color: #ff80e0;
    background: rgba(255, 128, 224, 0.07);
    box-shadow: 0 0 0 5px rgba(255, 128, 224, 0.06), inset 0 0 0 4px rgba(255, 128, 224, 0.12);
    transform: rotate(-13deg);
    font-family: var(--font-mono);
    text-align: center;
    line-height: 1;
    animation: stamp-pop 0.5s cubic-bezier(0.2, 1.4, 0.5, 1) both;
    pointer-events: none;
  }
  .sale-stamp-pct { font-size: 1.7rem; font-weight: 700; }
  .sale-stamp-off { font-size: 0.7rem; font-weight: 700; letter-spacing: 0.3em; margin-top: 1px; }
  .sale-stamp-sub { font-size: 0.46rem; letter-spacing: 0.22em; text-transform: uppercase; margin-top: 5px; opacity: 0.85; }
  @keyframes stamp-pop {
    0%   { transform: rotate(-13deg) scale(2); opacity: 0; }
    60%  { opacity: 1; }
    100% { transform: rotate(-13deg) scale(1); opacity: 1; }
  }
  @media (prefers-reduced-motion: reduce) { .sale-stamp { animation: none; } }

  /* ── Side-project separator before XeroDora ── */
  .side-project-break {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin: 3rem auto 1.75rem;
    max-width: 100%;
  }
  .side-project-break .spb-line {
    flex: 1;
    height: 1px;
    background: repeating-linear-gradient(
      90deg,
      var(--color-border-hover) 0 6px,
      transparent 6px 12px
    );
    opacity: 0.65;
  }
  .side-project-break .spb-label {
    font-family: var(--font-mono, monospace);
    /* Mobile-first: a touch bigger than the old value, no animation (battery). */
    font-size: 0.84rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: lowercase;
    color: var(--color-accent-light);
    padding: 0.32rem 0.85rem;
    border: 1px solid rgba(86, 87, 245, 0.5);
    border-radius: 5px;
    background: rgba(86, 87, 245, 0.1);
    box-shadow: 0 0 12px rgba(86, 87, 245, 0.25);
    text-shadow: 0 0 6px rgba(86, 87, 245, 0.45);
  }
  /* Desktop sizing: just smaller than mobile. */
  @media (min-width: 600px) {
    .side-project-break .spb-label {
      font-size: 0.7rem;
    }
  }
  /* Pulse animation gated on TRUE pointer-fine + hover-hover devices (real mouse/trackpad).
     Touch-only phones and tablets (and touch-2-in-1 laptops without a mouse attached) skip it. */
  @media (hover: hover) and (pointer: fine) and (min-width: 600px) {
    .side-project-break .spb-label {
      animation: spb-pulse 2.6s ease-in-out infinite;
    }
  }
  @keyframes spb-pulse {
    0%, 100% {
      box-shadow: 0 0 10px rgba(86, 87, 245, 0.2);
      border-color: rgba(86, 87, 245, 0.45);
    }
    50% {
      box-shadow: 0 0 22px rgba(86, 87, 245, 0.55), 0 0 36px rgba(255, 128, 224, 0.25);
      border-color: rgba(86, 87, 245, 0.85);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .side-project-break .spb-label { animation: none; }
  }
  /* Real touch devices (phones + tablets regardless of viewport width): no pulse.
     Battery-friendly. Catches landscape phones / tablets where viewport >= md but
     the device is still mobile. */
  @media (hover: none) and (pointer: coarse) {
    .side-project-break .spb-label { animation: none !important; }
  }
  .side-project-head .news-num { opacity: 0.55; }
  .side-project-head .news-title { font-size: clamp(1.4rem, 2.6vw, 2rem); }
  .side-project-pill {
    display: inline-flex;
    align-items: center;
    padding: 0.06rem 0.5rem;
    border-radius: 4px;
    font-family: var(--font-mono, monospace);
    font-size: 0.58rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #ff8a1a;
    background: rgba(255, 138, 26, 0.12);
    border: 1px solid rgba(255, 138, 26, 0.4);
    margin-right: 0.5rem;
  }
</style>
